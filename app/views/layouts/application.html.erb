<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Trade Tracker" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-slate-950 text-slate-100">
    <div class="fixed inset-0 -z-10 overflow-hidden">
      <div class="absolute left-1/2 top-0 h-96 w-96 -translate-x-1/2 rounded-full bg-cyan-500/20 blur-3xl"></div>
      <div class="absolute bottom-0 right-0 h-96 w-96 rounded-full bg-violet-500/20 blur-3xl"></div>
      <div class="absolute bottom-32 left-0 h-72 w-72 rounded-full bg-blue-500/10 blur-3xl"></div>
    </div>

    <nav class="sticky top-0 z-50 border-b border-white/10 bg-slate-950/70 backdrop-blur-xl">
      <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">
        <%= link_to root_path, class: "flex items-center gap-3" do %>
          <div class="flex h-10 w-10 items-center justify-center rounded-2xl bg-cyan-400/20 text-cyan-300 ring-1 ring-cyan-300/30">
            TT
          </div>

          <div>
            <p class="text-sm font-semibold tracking-wide text-white">Trade Tracker</p>
            <p class="text-xs text-slate-400">Performance analytics</p>
          </div>
        <% end %>

        <div class="flex items-center gap-3 text-sm">
          <% if user_signed_in? %>
            <%= link_to "Dashboard", root_path, class: "rounded-full px-4 py-2 text-slate-300 hover:bg-white/10 hover:text-white" %>
            <%= link_to "Trades", trades_path, class: "rounded-full px-4 py-2 text-slate-300 hover:bg-white/10 hover:text-white" %>
            <%= link_to "Upload", new_import_path, class: "rounded-full bg-cyan-400 px-4 py-2 font-medium text-slate-950 hover:bg-cyan-300" %>
            <%= button_to "Log out", destroy_user_session_path, method: :delete, class: "rounded-full px-4 py-2 text-slate-300 hover:bg-white/10 hover:text-white" %>
          <% else %>
            <%= link_to "Log in", new_user_session_path, class: "rounded-full px-4 py-2 text-slate-300 hover:bg-white/10 hover:text-white" %>
            <%= link_to "Sign up", new_user_registration_path, class: "rounded-full bg-cyan-400 px-4 py-2 font-medium text-slate-950 hover:bg-cyan-300" %>
          <% end %>
        </div>
      </div>
    </nav>

    <main class="mx-auto max-w-7xl px-6 py-8">
      <% if notice.present? %>
        <div class="mb-6 rounded-2xl border border-emerald-400/20 bg-emerald-400/10 px-4 py-3 text-emerald-200">
          <%= notice %>
        </div>
      <% end %>

      <% if alert.present? %>
        <div class="mb-6 rounded-2xl border border-red-400/20 bg-red-400/10 px-4 py-3 text-red-200">
          <%= alert %>
        </div>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>