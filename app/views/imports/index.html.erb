<section class="mb-8">
  <p class="text-sm text-cyan-300">Import history</p>
  <h1 class="mt-2 text-4xl font-bold tracking-tight text-white">Uploaded Files</h1>
  <p class="mt-3 max-w-2xl text-slate-400">
    Review every CSV file you have uploaded and check the parsing result for each import.
  </p>
</section>

<section class="mb-8 grid gap-4 md:grid-cols-3">
  <div class="rounded-3xl border border-white/10 bg-white/5 p-5 shadow-2xl backdrop-blur-xl">
    <p class="text-sm text-slate-400">Total Imports</p>
    <p class="mt-2 text-3xl font-bold text-white"><%= @imports.count %></p>
  </div>

  <div class="rounded-3xl border border-white/10 bg-white/5 p-5 shadow-2xl backdrop-blur-xl">
    <p class="text-sm text-slate-400">Completed</p>
    <p class="mt-2 text-3xl font-bold text-emerald-300"><%= @imports.where(status: "completed").count %></p>
  </div>

  <div class="rounded-3xl border border-white/10 bg-white/5 p-5 shadow-2xl backdrop-blur-xl">
    <p class="text-sm text-slate-400">Failed</p>
    <p class="mt-2 text-3xl font-bold text-red-300"><%= @imports.where(status: "failed").count %></p>
  </div>
</section>

<section class="rounded-3xl border border-white/10 bg-white/5 p-6 shadow-2xl backdrop-blur-xl">
  <div class="mb-5 flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
    <div>
      <h2 class="text-xl font-semibold text-white">Import Log</h2>
      <p class="text-sm text-slate-400">
        Newest uploads are shown first.
      </p>
    </div>

    <%= link_to "Upload CSV",
                new_import_path,
                class: "rounded-full bg-cyan-400 px-5 py-2.5 font-medium text-slate-950 hover:bg-cyan-300" %>
  </div>

  <% if @imports.any? %>
    <div class="overflow-x-auto">
      <table class="w-full min-w-[900px] text-left text-sm">
        <thead class="border-b border-white/10 text-slate-400">
          <tr>
            <th class="px-4 py-3">File</th>
            <th class="px-4 py-3">Platform</th>
            <th class="px-4 py-3">Status</th>
            <th class="px-4 py-3">Trades</th>
            <th class="px-4 py-3">Uploaded</th>
            <th class="px-4 py-3">Details</th>
          </tr>
        </thead>

        <tbody class="divide-y divide-white/10">
          <% @imports.each do |import| %>
            <tr class="hover:bg-white/5">
              <td class="px-4 py-3 font-medium text-white">
                <% if import.file.attached? %>
                  <%= import.file.filename %>
                <% else %>
                  No file
                <% end %>
              </td>

              <td class="px-4 py-3 text-slate-300">
                <%= import.source_platform %>
              </td>

              <td class="px-4 py-3">
                <span class="rounded-full px-3 py-1 text-xs font-medium <%= import.status == 'completed' ? 'bg-emerald-400/10 text-emerald-300' : import.status == 'failed' ? 'bg-red-400/10 text-red-300' : 'bg-yellow-400/10 text-yellow-300' %>">
                  <%= import.status %>
                </span>
              </td>

              <td class="px-4 py-3 text-slate-300">
                <%= import.trades.count %>
              </td>

              <td class="px-4 py-3 text-slate-400">
                <%= import.created_at.strftime("%b %-d, %Y %H:%M") %>
              </td>

              <td class="px-4 py-3">
                <%= link_to "View",
                            import_path(import),
                            class: "text-cyan-300 hover:text-cyan-200" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="rounded-2xl border border-white/10 bg-slate-900/60 p-6 text-slate-400">
      No imports yet. Upload your first CSV file to get started.
    </div>
  <% end %>
</section>