<h1>Trade Tracker Dashboard</h1>

<% if user_signed_in? %>
  <p>Welcome, <%= current_user.email %>.</p>

  <p>
    <%= link_to "Upload CSV", new_import_path %>
    |
    <%= link_to "View All Trades", trades_path %>
  </p>

  <h2>Performance Summary</h2>

  <table border="1" cellpadding="8">
    <tbody>
      <tr>
        <th>Total Trades</th>
        <td><%= @total_trades %></td>
      </tr>

      <tr>
        <th>Net P/L</th>
        <td>$<%= @net_pnl.round(2) %></td>
      </tr>

      <tr>
        <th>Wins</th>
        <td><%= @win_count %></td>
      </tr>

      <tr>
        <th>Losses</th>
        <td><%= @loss_count %></td>
      </tr>

      <tr>
        <th>Win Rate</th>
        <td><%= @win_rate %>%</td>
      </tr>

      <tr>
        <th>Average Win</th>
        <td>$<%= @average_win %></td>
      </tr>

      <tr>
        <th>Average Loss</th>
        <td>$<%= @average_loss %></td>
      </tr>

      <tr>
        <th>Profit Factor</th>
        <td><%= @profit_factor %></td>
      </tr>
    </tbody>
  </table>

  <h2>Equity Curve</h2>
  <% if @equity_curve.any? %>
    <%= line_chart @equity_curve, xtitle: "Trade Time", ytitle: "Cumulative P/L" %>
  <% else %>
    <p>No trade data yet.</p>
  <% end %>

  <h2>Daily P/L</h2>
  <% if @daily_pnl.any? %>
    <%= column_chart @daily_pnl, xtitle: "Day", ytitle: "Net P/L" %>
  <% else %>
    <p>No daily P/L data yet.</p>
  <% end %>

  <h2>Wins vs Losses</h2>
  <% if @total_trades.positive? %>
    <%= pie_chart @win_loss_chart %>
  <% else %>
    <p>No win/loss data yet.</p>
  <% end %>

  <br>

  <%= button_to "Log out", destroy_user_session_path, method: :delete %>
<% else %>
  <p>Upload trading CSV files, track your performance, and analyze your edge.</p>

  <p>
    <%= link_to "Sign up", new_user_registration_path %>
    |
    <%= link_to "Log in", new_user_session_path %>
  </p>
<% end %>