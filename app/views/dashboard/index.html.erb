<% if user_signed_in? %>
  <section class="mb-8">
    <p class="text-sm text-cyan-300">Welcome back, <%= current_user.email %></p>

    <div class="mt-2 flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <h1 class="text-4xl font-bold tracking-tight text-white">Trading Dashboard</h1>
        <p class="mt-3 max-w-2xl text-slate-400">
          Track your imported trades, monitor your equity curve, and review your trading performance.
        </p>
      </div>

      <div class="rounded-full border border-white/10 bg-white/5 p-1 backdrop-blur-xl">
        <% [
          ["7D", "7d"],
          ["30D", "30d"],
          ["1Y", "1y"],
          ["All", "all"]
        ].each do |label, value| %>
          <%= link_to label,
                      root_path(range: value),
                      class: "inline-flex rounded-full px-4 py-2 text-sm font-medium #{ @selected_range == value ? 'bg-cyan-400 text-slate-950' : 'text-slate-300 hover:bg-white/10 hover:text-white' }" %>
        <% end %>
      </div>
    </div>
  </section>

  <section class="mb-8 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
    <div class="rounded-3xl border border-white/10 bg-white/5 p-5 shadow-2xl backdrop-blur-xl">
      <p class="text-sm text-slate-400">Total Trades</p>
      <p class="mt-2 text-3xl font-bold text-white"><%= @total_trades %></p>
    </div>

    <div class="rounded-3xl border border-white/10 bg-white/5 p-5 shadow-2xl backdrop-blur-xl">
      <p class="text-sm text-slate-400">Net P/L</p>
      <p class="mt-2 text-3xl font-bold <%= @net_pnl.to_d >= 0 ? 'text-emerald-300' : 'text-red-300' %>">
        $<%= @net_pnl.round(2) %>
      </p>
    </div>

    <div class="rounded-3xl border border-white/10 bg-white/5 p-5 shadow-2xl backdrop-blur-xl">
      <p class="text-sm text-slate-400">Win Rate</p>
      <p class="mt-2 text-3xl font-bold text-white"><%= @win_rate %>%</p>
      <p class="mt-1 text-sm text-slate-500"><%= @win_count %> wins / <%= @loss_count %> losses</p>
    </div>

    <div class="rounded-3xl border border-white/10 bg-white/5 p-5 shadow-2xl backdrop-blur-xl">
      <p class="text-sm text-slate-400">Profit Factor</p>
      <p class="mt-2 text-3xl font-bold text-white"><%= @profit_factor %></p>
    </div>
  </section>

  <section class="mb-8 grid gap-4 md:grid-cols-2">
    <div class="rounded-3xl border border-white/10 bg-white/5 p-5 shadow-2xl backdrop-blur-xl">
      <p class="text-sm text-slate-400">Average Win</p>
      <p class="mt-2 text-2xl font-semibold text-emerald-300">$<%= @average_win %></p>
    </div>

    <div class="rounded-3xl border border-white/10 bg-white/5 p-5 shadow-2xl backdrop-blur-xl">
      <p class="text-sm text-slate-400">Average Loss</p>
      <p class="mt-2 text-2xl font-semibold text-red-300">$<%= @average_loss %></p>
    </div>
  </section>

  <section class="mb-8 rounded-3xl border border-white/10 bg-white/5 p-6 shadow-2xl backdrop-blur-xl">
    <div class="mb-4">
      <h2 class="text-xl font-semibold text-white">Equity Curve</h2>
      <p class="text-sm text-slate-400">Cumulative daily profit and loss for the selected range.</p>
    </div>

    <% if @equity_curve.any? %>
      <%= line_chart @equity_curve, xtitle: "Trade Time", ytitle: "Cumulative P/L", height: "360px" %>
    <% else %>
      <p class="text-slate-400">No trade data yet.</p>
    <% end %>
  </section>

  <section id="daily-review" class="mt-8 scroll-mt-24 rounded-3xl border border-white/10 bg-white/5 p-6 shadow-2xl backdrop-blur-xl">
    <div class="mb-6 flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
      <div>
        <p class="text-sm text-cyan-300">Daily journal foundation</p>
        <h2 class="mt-1 text-2xl font-semibold text-white">Daily Trade Review</h2>
        <p class="mt-2 text-sm text-slate-400">
          Review one trading day at a time. Notes and journaling will be added here next.
        </p>
      </div>

      <% if @selected_journal_date.present? %>
        <div class="flex items-center gap-3">
          <% if @previous_trade_date.present? %>
            <%= link_to "← Previous Day",
            root_path(range: @selected_range, journal_date: @previous_trade_date, anchor: "daily-review"),
            class: "rounded-full border border-white/10 px-4 py-2 text-sm font-medium text-slate-300 hover:bg-white/10 hover:text-white" %>
          <% else %>
            <span class="rounded-full border border-white/5 px-4 py-2 text-sm font-medium text-slate-600">
              ← Previous Day
            </span>
          <% end %>

          <div class="rounded-full bg-cyan-400 px-5 py-2 text-sm font-semibold text-slate-950">
            <%= @selected_journal_date.strftime("%b %-d, %Y") %>
          </div>

          <% if @next_trade_date.present? %>
            <%= link_to "Next Day →",
            root_path(range: @selected_range, journal_date: @next_trade_date, anchor: "daily-review"),
            class: "rounded-full border border-white/10 px-4 py-2 text-sm font-medium text-slate-300 hover:bg-white/10 hover:text-white" %>
          <% else %>
            <span class="rounded-full border border-white/5 px-4 py-2 text-sm font-medium text-slate-600">
              Next Day →
            </span>
          <% end %>
        </div>
      <% end %>
    </div>

    <% if @daily_review_trades.any? %>
      <div class="mb-6 grid gap-4 md:grid-cols-4">
        <div class="rounded-2xl border border-white/10 bg-slate-900/60 p-4">
          <p class="text-sm text-slate-400">Trades</p>
          <p class="mt-2 text-2xl font-bold text-white"><%= @daily_review_trades.count %></p>
        </div>

        <div class="rounded-2xl border border-white/10 bg-slate-900/60 p-4">
          <p class="text-sm text-slate-400">Daily P/L</p>
          <p class="mt-2 text-2xl font-bold <%= @daily_review_pnl.to_d >= 0 ? 'text-emerald-300' : 'text-red-300' %>">
            $<%= @daily_review_pnl.round(2) %>
          </p>
        </div>

        <div class="rounded-2xl border border-white/10 bg-slate-900/60 p-4">
          <p class="text-sm text-slate-400">Wins</p>
          <p class="mt-2 text-2xl font-bold text-emerald-300"><%= @daily_review_wins %></p>
        </div>

        <div class="rounded-2xl border border-white/10 bg-slate-900/60 p-4">
          <p class="text-sm text-slate-400">Losses</p>
          <p class="mt-2 text-2xl font-bold text-red-300"><%= @daily_review_losses %></p>
        </div>
      </div>

      <div class="max-h-[520px] overflow-auto rounded-2xl border border-white/10">
        <table class="w-full min-w-[900px] text-left text-sm">
          <thead class="sticky top-0 z-10 border-b border-white/10 bg-slate-950/95 text-slate-400 backdrop-blur">
            <tr>
              <th class="px-4 py-3">Time</th>
              <th class="px-4 py-3">Symbol</th>
              <th class="px-4 py-3">Side</th>
              <th class="px-4 py-3">Qty</th>
              <th class="px-4 py-3">Entry</th>
              <th class="px-4 py-3">Exit</th>
              <th class="px-4 py-3">Net P/L</th>
              <th class="px-4 py-3">Status</th>
              <th class="px-4 py-3">Details</th>
            </tr>
          </thead>

          <tbody class="divide-y divide-white/10">
            <% @daily_review_trades.each do |trade| %>
              <tr class="hover:bg-white/5">
                <td class="px-4 py-3 text-slate-400"><%= trade.exit_time&.strftime("%H:%M:%S") %></td>
                <td class="px-4 py-3 font-medium text-white"><%= trade.symbol %></td>

                <td class="px-4 py-3">
                  <span class="rounded-full px-3 py-1 text-xs font-medium <%= trade.side == 'long' ? 'bg-cyan-400/10 text-cyan-300' : 'bg-violet-400/10 text-violet-300' %>">
                    <%= trade.side %>
                  </span>
                </td>

                <td class="px-4 py-3 text-slate-300"><%= trade.quantity %></td>
                <td class="px-4 py-3 text-slate-300"><%= trade.entry_price %></td>
                <td class="px-4 py-3 text-slate-300"><%= trade.exit_price %></td>

                <td class="px-4 py-3 font-semibold <%= trade.net_pnl.to_d >= 0 ? 'text-emerald-300' : 'text-red-300' %>">
                  $<%= trade.net_pnl %>
                </td>

                <td class="px-4 py-3">
                  <span class="rounded-full px-3 py-1 text-xs font-medium <%= trade.status == 'win' ? 'bg-emerald-400/10 text-emerald-300' : trade.status == 'loss' ? 'bg-red-400/10 text-red-300' : 'bg-slate-400/10 text-slate-300' %>">
                    <%= trade.status %>
                  </span>
                </td>

                <td class="px-4 py-3">
                  <%= link_to "View",
                              trade_path(trade),
                              class: "text-cyan-300 hover:text-cyan-200" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="rounded-2xl border border-white/10 bg-slate-900/60 p-6 text-slate-400">
        No trades found for the selected range.
      </div>
    <% end %>
  </section>
<% else %>
  <section class="flex min-h-[70vh] items-center">
    <div class="max-w-3xl">
      <p class="text-sm font-medium text-cyan-300">Trading analytics made simple</p>
      <h1 class="mt-4 text-5xl font-bold tracking-tight text-white">
        Turn your trade reports into performance insight.
      </h1>
      <p class="mt-5 text-lg text-slate-400">
        Upload CSV files, parse your trades, and analyze win rate, equity curve, daily P/L, and more.
      </p>

      <div class="mt-8 flex gap-3">
        <%= link_to "Get started", new_user_registration_path, class: "rounded-full bg-cyan-400 px-6 py-3 font-medium text-slate-950 hover:bg-cyan-300" %>
        <%= link_to "Log in", new_user_session_path, class: "rounded-full border border-white/10 px-6 py-3 font-medium text-slate-200 hover:bg-white/10" %>
      </div>
    </div>
  </section>
<% end %>